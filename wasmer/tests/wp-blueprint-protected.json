            "code": "<?php require_once 'wp-load.php'; require_once(ABSPATH .'/wp-content/plugins/google-listings-and-ads/google-listings-and-ads.php'); require_once(ABSPATH .'/wp-admin/includes/plugin.php'); activate_plugin('google-listings-and-ads/google-listings-and-ads.php');"
